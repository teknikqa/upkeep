#!/usr/bin/env bash
# Pre-commit hook: runs formatting, linting, and tests on staged Go files.
# Symlink this into .git/hooks via: git config core.hooksPath .git-hooks
set -euo pipefail

# Skip if no Go files are staged.
STAGED_GO=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' || true)
if [ -z "$STAGED_GO" ]; then
    exit 0
fi

printf '==> pre-commit: checking staged Go files\n'

# 1. Format check — fail if any staged file isn't gofmt'd.
UNFORMATTED=$(gofmt -l $STAGED_GO 2>/dev/null || true)
if [ -n "$UNFORMATTED" ]; then
    printf 'ERROR: the following files need gofmt:\n'
    printf '  %s\n' $UNFORMATTED
    printf 'Run: go fmt ./...\n'
    exit 1
fi

# 2. go vet
printf '==> go vet ./...\n'
go vet ./...

# 3. golangci-lint (skip gracefully if not installed).
if command -v golangci-lint >/dev/null 2>&1; then
    printf '==> golangci-lint run\n'
    golangci-lint run
else
    printf '==> golangci-lint not found — skipping (install: https://golangci-lint.run/docs/install/)\n'
fi

# 4. Tests
printf '==> go test ./...\n'
go test ./... -timeout 120s

printf '==> pre-commit: all checks passed\n'
