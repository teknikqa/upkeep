#!/usr/bin/env bash
# Pre-commit hook: runs formatting, linting, and tests on staged Go files.
# Symlink this into .git/hooks via: git config core.hooksPath .git-hooks
set -euo pipefail

# Skip if no Go files are staged.
STAGED_GO=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' || true)
if [ -z "$STAGED_GO" ]; then
    exit 0
fi

printf '==> pre-commit: checking staged Go files\n'

# 1. Auto-format staged Go files and re-stage them.
gofmt -w $STAGED_GO
git add $STAGED_GO

# 2. Check go.mod/go.sum are tidy (only if they're staged or Go files changed).
printf '==> go mod tidy\n'
cp go.mod go.mod.bak && cp go.sum go.sum.bak
go mod tidy
if ! diff -q go.mod go.mod.bak >/dev/null 2>&1 || ! diff -q go.sum go.sum.bak >/dev/null 2>&1; then
    git add go.mod go.sum
    printf '    auto-tidied go.mod/go.sum\n'
fi
rm -f go.mod.bak go.sum.bak

# 3. go vet
printf '==> go vet ./...\n'
go vet ./...

# 4. golangci-lint (skip gracefully if not installed).
if command -v golangci-lint >/dev/null 2>&1; then
    printf '==> golangci-lint run\n'
    golangci-lint run
else
    printf '==> golangci-lint not found — skipping (install: https://golangci-lint.run/docs/install/)\n'
fi

# 5. Tests
printf '==> go test ./...\n'
go test ./... -timeout 120s

printf '==> pre-commit: all checks passed\n'
